# ---------------------------------------------------------------------------
# dotCMS connection
# Copy this file to `.env.local` and fill in the values from your environment.
# ---------------------------------------------------------------------------

# Base URL of your dotCMS instance (include the protocol, no trailing slash).
# For a cloud.dotcms.dev environment this looks like:
#   https://<your-env-name>.dotcms.cloud
NEXT_PUBLIC_DOTCMS_HOST=https://your-environment.dotcms.cloud

# A dotCMS API access key (JWT) with READ permissions.
# Admin → (gear) System → Users → pick a user → "API Access Key" → Request token.
# A read-only front-end user is recommended over an admin token.
NEXT_PUBLIC_DOTCMS_AUTH_TOKEN=

# The site you want to render. Either the site hostname (e.g. demo.dotcms.com)
# or its identifier (UUID). Leave blank to use the instance's default site.
NEXT_PUBLIC_DOTCMS_SITE_ID=

# ---------------------------------------------------------------------------
# Why NEXT_PUBLIC_*?  The dotCMS Universal Visual Editor runs the app inside an
# iframe in the admin and the React SDK talks to dotCMS from the browser, so the
# token must be readable client-side. Use a READ-ONLY token here. In production
# you'd proxy writes through a server route and keep privileged tokens server-side.
# ---------------------------------------------------------------------------
